	<parameter name="seaSkimmingHeight" type="float" title="Tinggi Sea Skimming (m)">2.5</parameter>
	<parameter name="launchAscentHeight" type="float" title="Tinggi Melambung Awal (m)">15</parameter>
	<parameter name="straightFlightDuration" type="float" title="Durasi Terbang Lurus (Detik)" tooltip="Berapa detik misil dipaksa lurus searah tabung sebelum mulai berbelok/menukik">1</parameter>
	<parameter name="targetNode" type="node" title="Target (KRI Golok)"/>
	<parameter name="selfShipNode" type="node" title="Kapal Sendiri (KRI Belati)"/>
