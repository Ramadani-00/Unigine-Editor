	<parameter name="waterExplosionPrefab" type="node" title="Prefab Ledakan Air"/>
	<parameter name="rocketMotorVFX" type="node" title="VFX Motor Roket (Terbang)"/>
	<parameter name="smokeWisp" type="node" title="Asap Awal (Smoke Wisp)"/>
	<parameter name="smokeMissile" type="node" title="Asap Ekor Terbang (Smoke Missile)"/>
	<parameter name="fireGlow" type="node" title="Efek Cahaya Api (Fire Glow)"/>
	<parameter name="sndMeluncurNode" type="node" title="Audio Meluncur (Snd_meluncur)"/>
	<parameter name="sndMeledakNode" type="node" title="Audio Meledak (Snd_meledak)"/>
	<parameter name="launchDelay" type="float" title="Jeda Luncur (Detik)">1</parameter>
